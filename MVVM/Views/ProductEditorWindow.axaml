<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MVVM.ViewModels"
        xmlns:categorys="clr-namespace:MVVM.Models.DTO.Categorys"
        x:Class="MVVM.Views.ProductEditorWindow"
        x:DataType="vm:ProductEditorViewModel"
        Title="Товар"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
        
        <StackPanel Margin="16" Spacing="10">
                <TextBlock Text="Товар" FontSize="18" FontWeight="SemiBold"/>

                <TextBox Watermark="Название" Text="{Binding Name, Mode=TwoWay}"/>
                <TextBox Watermark="Описание" Text="{Binding Description, Mode=TwoWay}"/>
                <TextBox Watermark="Цена" Text="{Binding Price, Mode=TwoWay}"/>
                <TextBox Watermark="Остаток" Text="{Binding Stock, Mode=TwoWay}"/>

                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="categorys:CategoryReadDto">
                                        <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                        </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Сохранить" Click="OkButton_Click"/>
                        <Button Content="Отмена" Click="CancelButton_Click"/>
                </StackPanel>
        </StackPanel>
</Window>
