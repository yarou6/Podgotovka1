<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MVVM.ViewModels"
        x:Class="MVVM.Views.CategoryEditorWindow"
        x:DataType="vm:CategoryEditorViewModel"
        Title="Категория"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="10">
        <TextBlock Text="Категория" FontSize="18" FontWeight="SemiBold"/>

        <TextBox Watermark="Название" Text="{Binding Name, Mode=TwoWay}"/>
        <TextBox Watermark="Описание" Text="{Binding Description, Mode=TwoWay}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Сохранить" Click="OkButton_Click"/>
            <Button Content="Отмена" Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
